{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/subscribe/?", "dest": "/api/subscribe.js" },
    { "src": "/api/lexicon/?", "dest": "/api/lexicon.js" },
    { "src": "^/$", "dest": "/public/faraday-home.html" },
    { "src": "/profile", "dest": "/public/faraday-subscriber-profile-v7.html" },
    { "src": "/wattl", "dest": "/public/wattl/index.html" },
    { "src": "/wattl/(.*)", "dest": "/public/wattl/$1" },
    { "src": "/rackl", "dest": "/public/rackl/index.html" },
    { "src": "/rackl/(.*)", "dest": "/public/rackl/$1" },
    { "src": "/academy", "dest": "/public/academy/index.html" },
    { "src": "/academy/(.*)", "dest": "/public/academy/$1" },
    { "src": "/academy-store", "dest": "/public/academy-store/index.html" },
    { "src": "/academy-store/(.*)", "dest": "/public/academy-store/$1" },
    { "src": "/daily-challenge", "dest": "/public/daily-challenge-index.html" },
    { "src": "/teams", "dest": "/public/teams.html" },
    { "src": "/sitemap.xml", "dest": "/public/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/public/robots.txt" },
    { "src": "/daily-challenge/(.*)", "dest": "/public/daily-challenge/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
