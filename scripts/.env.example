# Gutenberg (FAR-156) — Notion → LearnWorlds publish pipeline
# Copy to .env (or set in Vercel / shell env). NEVER commit real secrets.

# --- Notion (source) ---
# Internal integration token with read access to the Academy course pages.
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Notion API version pinned by the script (override only if Notion bumps it).
NOTION_VERSION=2022-06-28

# --- LearnWorlds (destination) ---
# School slug from https://<LW_SCHOOL_ID>.learnworlds.com
LW_SCHOOL_ID=your-school-slug
# Admin API bearer token (Settings → Developers → API).
LW_API_KEY=lw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Some LearnWorlds schools require a client-id header (Lw-Client). Optional.
LW_CLIENT_ID=
# Override the API base if your school uses a non-default host. Optional;
# defaults to https://<LW_SCHOOL_ID>.learnworlds.com/admin/api/v2
LW_API_BASE=

# --- Gutenberg behavior ---
# Days between dripped sections (default 7).
GUTENBERG_DRIP_INTERVAL_DAYS=7
